---
import { withBase } from '@/lib/url';
import Badge from './Badge.astro';

interface Props {
  id: string;
  name: string;
  classification: string;
  image?: string;
}

const classLabels: Record<string, string> = {
  aerial: 'Aéreo',
  ground: 'Terrestre',
  aquatic: 'Acuático',
  turret: 'Torreta',
  'boss-minion': 'Escolta de jefe',
  other: 'Otro',
};

const { id, name, classification, image } = Astro.props;
---

<a class="enemy-card panel-sm panel" href={withBase(`/enemies/${id}`)}>
  <div class="thumb">
    {image ? <img src={withBase(image)} alt="" loading="lazy" /> : <span class="fallback">?</span>}
  </div>
  <h3>{name}</h3>
  <Badge>{classLabels[classification] ?? classification}</Badge>
</a>

<style>
  .enemy-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--text);
  }

  .enemy-card:hover {
    text-decoration: none;
    border-color: var(--accent);
  }

  .thumb {
    width: 100%;
    aspect-ratio: 1;
    background: var(--bg-raised);
    border: 1px solid var(--border-soft);
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fallback {
    font-family: var(--font-display);
    color: var(--text-dim);
    font-size: 1.5rem;
  }

  h3 {
    margin: 0;
    font-size: 0.95rem;
  }
</style>
