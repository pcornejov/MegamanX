---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import GameCard from '@/components/GameCard.astro';
import { withBase } from '@/lib/url';

const allGames = await getCollection('games');
const mainline = allGames.filter((g) => g.data.category === 'mainline').sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Mega Man X — Guía del Cazador">
  <section class="hero">
    <div class="container">
      <p class="eyebrow">⌐ Base de datos de Maverick Hunters</p>
      <h1>La guía completa de la saga <span>Mega Man X</span></h1>
      <p class="lede">
        Mecánicas, orden recomendado de jefes, personajes, Reploids, Mavericks, enemigos y curiosidades de
        los ocho juegos principales — con video de referencia para cada ubicación clave.
      </p>
      <div class="actions">
        <a class="cta" href={withBase('/games')}>Explorar juegos</a>
        <a class="cta ghost" href={withBase('/characters')}>Ver personajes</a>
      </div>
    </div>
  </section>

  <section class="container games-section">
    <SectionHeading eyebrow="Serie principal">Juegos</SectionHeading>
    <div class="grid grid-cards">
      {
        mainline.map((game) => (
          <GameCard
            id={game.id}
            title={game.data.title}
            subtitle={game.data.subtitle}
            releaseYear={game.data.releaseYear}
            platforms={game.data.platforms}
            description={game.data.description}
            accentColor={game.data.accentColor}
            coverImage={game.data.coverImage}
            comingSoon={game.data.comingSoon}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: 3.5rem 2.5rem;
    border-bottom: 1px solid var(--border);
    background: radial-gradient(ellipse at top left, rgba(46, 111, 242, 0.16), transparent 60%);
  }

  .eyebrow {
    font-family: var(--font-mono);
    color: var(--energy);
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    max-width: 18ch;
  }

  h1 span {
    color: var(--accent-glow);
  }

  .lede {
    max-width: 60ch;
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  .actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  .cta {
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.7rem 1.4rem;
    background: var(--accent);
    color: #04070d;
    clip-path: var(--panel-clip-sm);
  }

  .cta:hover {
    text-decoration: none;
    background: var(--accent-glow);
  }

  .cta.ghost {
    background: transparent;
    border: 1px solid var(--accent);
    color: var(--accent-glow);
  }

  .games-section {
    padding-block: 3rem;
  }
</style>
